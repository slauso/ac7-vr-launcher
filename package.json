{
  "name": "ac7-vr-launcher",
  "version": "1.0.0",
  "description": "Visual wizard launcher for Ace Combat 7 VR with UEVR and Quest 3 Virtual Desktop setup.",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "webpack serve --config webpack.config.ts --env rendererDev=true",
    "dev:main": "wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "webpack --config webpack.config.ts",
    "lint": "tsc --noEmit",
    "test": "npm run lint",
    "package": "npm run build && electron-builder --win nsis"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slauso/ac7-vr-launcher.git"
  },
  "keywords": [
    "electron",
    "typescript",
    "react",
    "uevr",
    "ace-combat-7"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/slauso/ac7-vr-launcher/issues"
  },
  "homepage": "https://github.com/slauso/ac7-vr-launcher#readme",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
